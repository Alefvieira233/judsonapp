# ── Supabase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Upstash Redis (optional, recommended for production) ─────────────────────
# Without these, rate-limiting falls back to in-memory (resets on cold start).
# Free tier at https://upstash.com — create a "Redis" database, copy the REST
# URL and token here.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Sentry (optional) ────────────────────────────────────────────────────────
# Without DSN, Sentry init is a no-op. To enable: create a Next.js project on
# https://sentry.io and paste the DSN below. For source-map upload set the
# auth token + org/project in the Vercel project env vars.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── Asaas (Pix/cartão/boleto recorrente). Sandbox: https://sandbox.asaas.com/api/v3
# Sem ASAAS_API_KEY o app cai pro fluxo manual via WhatsApp (sem mudança de código).
# Em produção: criar conta em asaas.com, gerar API key (Configurações → Integrações),
# definir ASAAS_WEBHOOK_SECRET (qualquer string forte) e cadastrar a URL do webhook
# `/api/webhooks/asaas` no painel Asaas com o mesmo secret no campo "Token".
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_SECRET=

# ── Web Push / VAPID (optional) ──────────────────────────────────────────────
# Push notifications use the standard Web Push API with VAPID auth — no
# Firebase / FCM dependency. Generate a key pair once with:
#   npx web-push generate-vapid-keys
# Paste the public key into BOTH VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY
# (the latter is exposed to the browser so the SW can subscribe).
# CRON_SECRET protects /api/cron/*. Set it on Vercel and the same value goes in
# the Vercel Cron config (Vercel sends "Authorization: Bearer ${CRON_SECRET}").
VAPID_SUBJECT=mailto:contato@judsonlobato.com.br
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
CRON_SECRET=

# ── Multi-tenant SaaS ────────────────────────────────────────────────────────
# Multi-tenant SaaS mode. false = cliente-zero (Judson hardcoded). true =
# resolve tenant via host header + landing pública vira pitch SaaS.
MULTI_TENANT_ENABLED=false

# Site URL used by checkout/portal redirects e magic links. Em prod aponta pra
# https://app.judsonapp.com.br (ou domínio custom). Em dev: http://localhost:3000.
NEXT_PUBLIC_SITE_URL=

# Stripe (cobrança do PERSONAL pela mensalidade do app — não confundir com
# Asaas, que cobra a aluna). Sem STRIPE_SECRET_KEY o signup self-serve cai pro
# modo "trial gratuito" sem cobrar. STRIPE_PRICE_STARTER é o price ID do plano
# Starter (R$ 79/mês). Em prod: criar conta em stripe.com, criar Product +
# recurring Price em BRL, copiar price_xxx.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
